{
  "name": "gateway-adk-dev",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "app",
  "runServices": [
    "app"
  ],
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI"
    }
  },
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
  "postAttachCommand": "sh -lc \"pgrep -f 'uvicorn app.main:app' > /dev/null || nohup uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 > /tmp/uvicorn.log 2>&1 &\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
